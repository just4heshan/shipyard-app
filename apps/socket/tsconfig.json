{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@shipyard/db": ["../../packages/db/src"],
      "@shipyard/logger": ["../../packages/logger/src"],
      "@shipyard/types": ["../../packages/types/src"],
      "@shipyard/types/socket": ["../../packages/types/src/socket"],
      "@shipyard/types/task": ["../../packages/types/src/task"]
    }
  },
  "include": ["src"]
}
