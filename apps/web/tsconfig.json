{
  "extends": "@shipyard/typescript-config/nextjs.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "strictNullChecks": true,
    "paths": {
      "@/*": ["./*"],
      "@/trpc/*": ["./src/trpc/*"],
      "@shipyard/ui": ["../../packages/ui/src"],
      "@shipyard/ui/*": ["../../packages/ui/src/*"],
      "@shipyard/api": ["../../packages/api/src"],
      "@shipyard/api/lib": ["../../packages/api/src/lib"],
      "@shipyard/email": ["../../packages/email"],
      "@shipyard/db": ["../../packages/db/src"],
      "@shipyard/db/enum": ["../../packages/db/src/enum"],
      "@shipyard/types": ["../../packages/types/src"],
      "@shipyard/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
